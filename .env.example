# Hugging Face dataset
HF_DATASET_ID=ManikaSaini/zomato-restaurant-recommendation
HF_HOME=.cache/huggingface

# LLM (Phase 3)
GROQ_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3

# Filtering pipeline
TOP_N_CANDIDATES=30
TOP_K_RECOMMENDATIONS=5

# Budget bands (INR cost for two) — low: 0–500, medium: 501–1500, high: 1501+
BUDGET_LOW_MAX=500
BUDGET_MEDIUM_MAX=1500

# Data cache (optional pickle cache for preprocessed restaurants)
DATA_CACHE_PATH=data/cache/restaurants.pkl
USE_DATA_CACHE=true